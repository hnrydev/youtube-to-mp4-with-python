{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "vite --port 3000",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "functions": {
    "api/**/*.py": {
      "maxDuration": 60,
      "memory": 3008,
      "excludeFiles": "{node_modules/**,.git/**,dist/**,src/**,*.md,**/*.test.*}"
    }
  }
}
